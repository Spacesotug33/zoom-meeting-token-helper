# Zoom API credentials (from Zoom App Marketplace > Server-to-Server OAuth app)
ZOOM_CLIENT_ID=your_client_id_here
ZOOM_CLIENT_SECRET=your_client_secret_here
ZOOM_ACCOUNT_ID=your_account_id_here

# Optional: specific Zoom user email to create meetings for (default: account owner)
ZOOM_USER_EMAIL=user@example.com
